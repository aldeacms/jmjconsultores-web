---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "JMJ Consultores - Gestión de Riesgos en Minería" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/assets/branding/favicon-jmj-consultores.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
