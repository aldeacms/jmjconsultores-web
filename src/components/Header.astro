---
---
<header id="main-header" class="fixed w-full top-0 z-[100] bg-white/95 backdrop-blur-md border-b border-slate-100 shadow-sm transition-all duration-500 group/header">
    <!-- Main Navbar Container -->
    <div id="header-container" class="relative z-[130] max-w-7xl mx-auto px-6 h-24 flex items-center justify-between transition-all duration-500">
        <a href="/" class="transition-all duration-300 group-[.menu-open]/header:brightness-0 group-[.menu-open]/header:invert group-[.menu-open]/header:opacity-100">
            <img src="/assets/branding/logo.svg" alt="JMJ Consultores" class="h-11 md:h-13 object-contain transition-all">
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex gap-10 text-[12px] font-bold text-jmj-blue tracking-[0.15em] uppercase">
            <a href="/" class="relative group py-2">
                <span class="hover:text-jmj-orange transition-colors duration-300">Inicio</span>
                <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-jmj-orange transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="/nosotros" class="relative group py-2">
                <span class="hover:text-jmj-orange transition-colors duration-300">Quiénes Somos</span>
                <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-jmj-orange transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="/servicios" class="relative group py-2">
                <span class="hover:text-jmj-orange transition-colors duration-300">Servicios</span>
                <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-jmj-orange transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="/contacto" class="relative group py-2">
                <span class="hover:text-jmj-orange transition-colors duration-300">Contacto</span>
                <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-jmj-orange transition-all duration-300 group-hover:w-full"></span>
            </a>
        </nav>

        <div class="flex items-center gap-6">
            <a href="/contacto"
                class="hidden lg:inline-block bg-jmj-orange text-white px-7 py-3 rounded text-[12px] font-bold uppercase tracking-wider hover:bg-[#d14b1c] transition-all duration-300 shadow-lg hover:shadow-jmj-orange/30 hover:-translate-y-0.5">
                Evaluar Proyecto
            </a>
            
            <!-- Mobile Menu Button (Hamburger) -->
            <button id="mobile-menu-btn" class="md:hidden relative w-10 h-10 flex flex-col items-center justify-center gap-1.5 focus:outline-none transition-colors duration-300" aria-label="Menu">
                <span class="block w-6 h-0.5 bg-jmj-blue transition-all duration-300 origin-center group-[.menu-open]/header:bg-white group-[.menu-open]/header:rotate-45 group-[.menu-open]/header:translate-y-2"></span>
                <span class="block w-6 h-0.5 bg-jmj-blue transition-all duration-300 group-[.menu-open]/header:opacity-0"></span>
                <span class="block w-6 h-0.5 bg-jmj-blue transition-all duration-300 origin-center group-[.menu-open]/header:bg-white group-[.menu-open]/header:-rotate-45 group-[.menu-open]/header:-translate-y-2"></span>
            </button>
        </div>
    </div>

    <!-- Mobile Menu Drawer (Fullscreen) -->
    <div id="mobile-menu" class="fixed inset-0 w-screen h-[100dvh] bg-jmj-blue z-[120] translate-x-full transition-transform duration-500 ease-in-out md:hidden flex flex-col items-center justify-center overflow-hidden">
        <nav class="flex flex-col items-center gap-8 text-white text-2xl font-bold uppercase tracking-[0.2em] text-center w-full px-10">
            <a href="/" class="mobile-link opacity-0 translate-y-8 transition-all duration-500 hover:text-jmj-orange">Inicio</a>
            <a href="/nosotros" class="mobile-link opacity-0 translate-y-8 transition-all duration-500 hover:text-jmj-orange">Quiénes Somos</a>
            <a href="/servicios" class="mobile-link opacity-0 translate-y-8 transition-all duration-500 hover:text-jmj-orange">Servicios</a>
            <a href="/contacto" class="mobile-link opacity-0 translate-y-8 transition-all duration-500 hover:text-jmj-orange">Contacto</a>
            
            <a href="/contacto" class="mobile-link opacity-0 translate-y-8 transition-all duration-500 mt-6 bg-jmj-orange text-white px-10 py-4 rounded text-sm font-bold uppercase tracking-widest shadow-2xl">
                Evaluar Proyecto
            </a>
        </nav>
    </div>
</header>

<script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const header = document.getElementById('main-header');
    const container = document.getElementById('header-container');
    const links = document.querySelectorAll('.mobile-link');

    const toggleMenu = () => {
        const isOpen = header.classList.toggle('menu-open');
        menu.classList.toggle('translate-x-0', isOpen);
        menu.classList.toggle('translate-x-full', !isOpen);
        
        // Block scroll
        if (isOpen) {
            document.body.style.overflow = 'hidden';
            document.body.style.height = '100vh';
        } else {
            document.body.style.overflow = '';
            document.body.style.height = '';
        }

        // Link animations
        if (isOpen) {
            links.forEach((link, i) => {
                setTimeout(() => {
                    link.classList.remove('opacity-0', 'translate-y-8');
                }, 100 * (i + 1));
            });
        } else {
            links.forEach(link => {
                link.classList.add('opacity-0', 'translate-y-8');
            });
        }
    };

    btn.addEventListener('click', toggleMenu);

    links.forEach(link => {
        link.addEventListener('click', (e) => {
            // Only toggle if it's an anchor on the same page
            if (link.getAttribute('href').startsWith('#')) {
                toggleMenu();
            }
        });
    });

    // Scroll effect for header size
    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            container.style.height = '80px';
        } else {
            container.style.height = '96px';
        }
    });
</script>

<style>
    /* Absolute reset for the drawer */
    #mobile-menu {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100vw !important;
        height: 100dvh !important;
    }
</style>
